PORT=3000
NODE_ENV=development
JWT_SECRET=your-jwt-secret
JWT_SECRET_ACCESS=your_access_secret
JWT_SECRET_REFRESH=your_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
AUTH_USER_TABLE=users
AUTH_USER_ID_COLUMN=id
AUTH_USER_FULL_NAME_COLUMN=full_name
AUTH_USER_EMAIL_COLUMN=email
AUTH_USER_PASSWORD_COLUMN=password_hash
AUTH_USER_ROLE_COLUMN=role

# Supabase PostgreSQL connection string.
# Replace [YOUR-PASSWORD] with the database password from:
# Supabase Dashboard > Project Settings > Database
DATABASE_URL=postgresql://postgres.vzxmdvesbbjaubgasihb:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Keep SSL enabled for Supabase.
DB_SSL=true
DB_POOL_MAX=10

# ─── Email (Phase 3) ────────────────────────────────────────────────────────
# If not configured, invitation emails are printed to the console (dev mode).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=NATEAT <no-reply@nateat.vn>

# The URL of the frontend user app - used to build invitation acceptance links.
FRONTEND_USER_URL=http://localhost:5173

# ─── Security (Phase 4) ──────────────────────────────────────────────────────
# Max failed login attempts before account lock (default: 5)
MAX_FAILED_LOGIN_ATTEMPTS=5
# Password reset link TTL in minutes (default: 60)
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# ─── CORS (Production) ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty in development to allow all origins.
# Example: https://nateat-user.vercel.app,https://nateat-admin.vercel.app
CORS_ORIGINS=
